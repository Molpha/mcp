# Signer backend: memory (local keypair) or keychain (Privy / Turnkey).
SIGNER_BACKEND=memory
KEYCHAIN_BACKEND=

# Memory signer (default).
OWNER_KEYPAIR=./secrets/owner.json

# Privy keychain signer.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_ID=
PRIVY_WALLET_ADDRESS=

# Turnkey keychain signer.
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=
TURNKEY_WALLET_ADDRESS=

# Runtime layer: same wallet signs on-chain txs and gateway authSig.
# Leave GATEWAY_ENDPOINTS unset to use the default Molpha gateway
# (https://brebeneskul.gateway.molpha.io). Must not be a Solana RPC URL.
GATEWAY_ENDPOINTS=
SOLANA_RPC=https://api.devnet.solana.com

# Optional runtime pins.
MOLPHA_EVM_NETWORKS=evm-sepolia
MOLPHA_STARKNET_NETWORKS=starknet-sepolia

# Guardrails (server-side, v1).
MOLPHA_MAX_EXECUTES_PER_DAY=100
MOLPHA_DRY_RUN=false

# x402 self-funded pay-per-request (molpha_fetch_verified payment: "x402" or "auto").
# Caps are decimal USDC (6 decimals); the MCP refuses to fund a round above
# MOLPHA_X402_MAX_PRICE_USDC or once MOLPHA_X402_MAX_SPEND_PER_DAY_USDC is spent for the day.
MOLPHA_X402_MAX_PRICE_USDC=1
MOLPHA_X402_MAX_SPEND_PER_DAY_USDC=10
# Optional: the settling gateway's PDA (base58), if known out of band. Only
# needed to skip the discovery round-trip when the x402 escrow is already
# funded — otherwise it's learned automatically from the gateway's first 402.
MOLPHA_X402_GATEWAY_PDA=

# Bootstrap CLI only (subscribe/extend — debits USDC).
MOLPHA_PLAN=Basic
MAX_PRICE_USDC=
