# Signer backend: memory (local keypair) or keychain (Privy / Turnkey).
SIGNER_BACKEND=memory
KEYCHAIN_BACKEND=

# Memory signer (default).
OWNER_KEYPAIR=./secrets/owner.json

# Privy keychain signer.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_ID=
PRIVY_WALLET_ADDRESS=

# Turnkey keychain signer.
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=
TURNKEY_WALLET_ADDRESS=

# Runtime layer: same wallet signs on-chain txs and gateway authSig.
GATEWAY_ENDPOINTS=https://gateway.molpha.io
SOLANA_RPC=https://api.devnet.solana.com

# Optional runtime pins.
PROGRAM_ID=
MOLPHA_EVM_NETWORKS=evm-sepolia
MOLPHA_STARKNET_NETWORKS=starknet-sepolia

# Guardrails (server-side, v1).
MOLPHA_MAX_JOBS_PER_DAY=10
MOLPHA_MAX_EXECUTES_PER_DAY=100
MOLPHA_DRY_RUN=false

# Bootstrap CLI only (subscribe/extend — debits USDC).
MOLPHA_PLAN=Basic
MAX_PRICE_USDC=
